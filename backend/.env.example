# ========== Backend (Node on Railway or local) ==========
# Copy to ".env" for local runs only. On Railway, set the same NAMES in "Variables".

# Local port (Railway sets PORT automatically — you usually do not set this on Railway)
PORT=4000

# --- Required on Railway AND local ---
# Value = entire contents of the Firebase service account JSON file (one object).
# How to get it: Firebase Console → Project settings → Service accounts → Generate new private key.
# Paste: either the raw multi-line JSON, OR one minified line (both work if JSON.parse succeeds).
#
# Variable name must match exactly:
FIREBASE_SERVICE_ACCOUNT_JSON=
